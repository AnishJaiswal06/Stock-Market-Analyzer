# Stock Analyzer Configuration
TARGET_TICKER=AAPL
SEC_USER_AGENT_EMAIL=your_email@example.com

# Model Hyperparameters
LSTM_SEQUENCE_LENGTH=60
PREDICTION_HORIZON=5
CLASSIFICATION_THRESHOLD=0.01
MODEL_EPOCHS=15
MODEL_BATCH_SIZE=64
MODEL_HIDDEN_SIZE=64
MODEL_NUM_LAYERS=2
MODEL_DROPOUT=0.2
MODEL_LEARNING_RATE=0.001

# Backtesting Parameters
INITIAL_CAPITAL=10000
RISK_FREE_RATE=0.02
SIGNAL_THRESHOLD=0.5

# Transaction costs (fraction per side: 0.0005 = 0.05%)
COMMISSION_PCT=0.0005
SLIPPAGE_PCT=0.0005

# ATR risk management (position sizing + stops from ATR_14)
USE_ATR_RISK=false
ATR_STOP_MULT=2.0
ATR_TP_MULT=3.0
RISK_PER_TRADE=0.02

# Model persistence (saved_models/<TICKER>/)
SAVE_MODEL=true

# Walk-forward validation (python walkforward.py)
WF_TRAIN_ROWS=500
WF_TEST_ROWS=63
WF_EPOCHS=15